# ---- Server ----
PORT=4000

# ---- Database ----
# When USE_MEMORY_DB=true an in-process mongodb-memory-server is started and
# MONGO_URI is ignored (great for local dev — no Mongo install required).
# Set USE_MEMORY_DB=false to use a real MongoDB at MONGO_URI.
USE_MEMORY_DB=true
MONGO_URI=mongodb://127.0.0.1:27017/moldati

# ---- Auth / JWT ----
# REQUIRED in production: set a strong, unique random secret (e.g.
# `openssl rand -hex 32`). Leaving this blank (or the old placeholder) makes the
# server REFUSE to start when NODE_ENV=production.
JWT_SECRET=
JWT_EXPIRES=30d

# ---- Bootstrap admin (seeded on first start) ----
# REQUIRED in production: set a strong ADMIN_PASSWORD. A blank value or the
# well-known default `admin123` makes the server REFUSE to start when
# NODE_ENV=production.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=

# ---- Cloud backups ----
# Directory where uploaded SQLite snapshots are stored (per-account subfolders).
BACKUP_DIR=./backups
# Keep only the N newest backups per account.
MAX_BACKUPS=10
